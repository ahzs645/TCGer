{
  "name": "tcg-collection-manager",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@11.7.0",
  "workspaces": [
    "backend",
    "convex-backend",
    "frontend",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev --filter=@tcg/backend",
    "dev:convex": "turbo dev --filter=@tcg/convex-backend",
    "dev:frontend": "npm --prefix frontend run dev:host",
    "docker:dev": "docker compose -f docker/docker-compose.yml --env-file .env.docker up --build",
    "docker:dev:bulk": "docker compose -f docker/docker-compose.yml --env-file .env.docker --profile bulk up --build",
    "docker:dev:legacy": "BACKEND_MODE=hybrid docker compose -f docker/docker-compose.yml --env-file .env.docker --profile legacy up --build",
    "docker:dev:legacy:bulk": "BACKEND_MODE=hybrid docker compose -f docker/docker-compose.yml --env-file .env.docker --profile legacy --profile bulk up --build",
    "docker:dev:full": "docker compose -f docker/docker-compose.yml --env-file .env.docker --profile frontend up --build",
    "docker:dev:full:bulk": "docker compose -f docker/docker-compose.yml --env-file .env.docker --profile frontend --profile bulk up --build",
    "docker:hash:pokemon": "docker compose -f docker/docker-compose.card-scan.yml --env-file .env.docker up --build --abort-on-container-exit --exit-code-from card-hash-builder card-hash-builder",
    "docker:hash:down": "docker compose -f docker/docker-compose.card-scan.yml --env-file .env.docker down",
    "docker:down": "docker compose -f docker/docker-compose.yml --env-file .env.docker down",
    "docker:down:volumes": "docker compose -f docker/docker-compose.yml --env-file .env.docker down -v",
    "dev:marketing": "npm --prefix marketing-site run dev",
    "docs:dev": "npm --prefix docs run dev",
    "docs:build": "npm --prefix docs run build",
    "docs:preview": "npm --prefix docs run preview",
    "dev:all": "turbo dev",
    "build": "turbo build",
    "build:marketing": "npm --prefix marketing-site run build",
    "lint": "turbo lint",
    "test": "turbo test",
    "format": "turbo format"
  },
  "engines": {
    "node": ">=18.17.0",
    "npm": ">=9.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.2",
    "turbo": "^2.8.9"
  }
}
