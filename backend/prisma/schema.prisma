generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String       @id @default(uuid())
  email       String?
  username    String       @unique
  passwordHash String
  isAdmin     Boolean      @default(false)
  discordId   String?
  showCardNumbers Boolean  @default(true)
  showPricing     Boolean  @default(true)
  enabledYugioh   Boolean  @default(true)
  enabledMagic    Boolean  @default(true)
  enabledPokemon  Boolean  @default(true)
  defaultGame     String?
  binders     Binder[]
  collections Collection[]
  tags        Tag[]
  wishlists   Wishlist[]
  decks       Deck[]
  priceAlerts PriceAlert[]
  transactions Transaction[]
  shopConnections ShopConnection[]
  sealedInventory SealedInventory[]
  tradesSent     Trade[]   @relation("TradesSent")
  tradesReceived Trade[]   @relation("TradesReceived")
  automations    Automation[]
  shipments      Shipment[]
  notificationChannels NotificationChannel[]
  notifications  Notification[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model AppSettings {
  id                    Int      @id @default(1)
  publicDashboard       Boolean  @default(false)
  publicCollections     Boolean  @default(false)
  requireAuth           Boolean  @default(true)
  appName               String   @default("TCG Manager")
  scrydexApiKey         String?
  scrydexTeamId         String?
  scryfallApiBaseUrl    String?
  ygoApiBaseUrl         String?
  scrydexApiBaseUrl     String?
  tcgdexApiBaseUrl      String?
  updatedAt             DateTime @updatedAt
}

model TcgGame {
  id           Int      @id @default(autoincrement())
  code         String   @unique
  displayName  String
  apiEndpoint  String?
  schemaVersion String?
  enabled      Boolean  @default(true)
  cards        Card[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Card {
  id            String          @id @default(uuid())
  tcgGameId     Int
  externalId    String
  name          String
  setCode       String?
  setName       String?
  rarity        String?
  imageUrl      String?
  imageUrlSmall String?
  tcgSpecific   Json?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  tcgGame    TcgGame    @relation(fields: [tcgGameId], references: [id])
  collections Collection[]
  priceHistory PriceHistory[]
  yugiohCard  YugiohCard?
  magicCard   MagicCard?
  pokemonCard PokemonCard?

  @@unique([tcgGameId, externalId])
}

model Binder {
  id          String       @id @default(uuid())
  userId      String
  name        String
  description String?
  colorHex    String?
  shareToken  String?      @unique
  isPublic    Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  collections Collection[]
}

model Collection {
  id               String   @id @default(uuid())
  userId           String
  cardId           String
  binderId         String?
  quantity         Int      @default(1)
  condition        String?
  language         String?
  notes            String?
  price            Decimal? @db.Decimal(10, 2)
  acquisitionPrice Decimal? @db.Decimal(10, 2)
  isFoil           Boolean  @default(false)
  isSigned         Boolean  @default(false)
  isAltered        Boolean  @default(false)
  imageUrls        String[] @default([])
  customAttributes Json?
  serialNumber     String?
  acquiredAt       DateTime?
  gradingCompany   String?
  gradingScore     String?
  certNumber       String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  card   Card    @relation(fields: [cardId], references: [id], onDelete: Cascade)
  binder Binder? @relation(fields: [binderId], references: [id], onDelete: SetNull)
  tags   CollectionTag[]
}

model Tag {
  id        String   @id @default(uuid())
  userId    String
  label     String
  colorHex  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignments CollectionTag[]

  @@unique([userId, label])
}

model CollectionTag {
  collectionId String
  tagId        String
  assignedAt   DateTime @default(now())

  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  tag        Tag        @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([collectionId, tagId])
}

model PriceHistory {
  id         BigInt   @id @default(autoincrement())
  cardId     String
  price      Decimal? @db.Decimal(10, 2)
  currency   String   @default("USD")
  source     String?
  recordedAt DateTime @default(now())

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)
}

model YugiohCard {
  cardId      String @id
  cardType    String?
  monsterType String?
  attribute   String?
  level       Int?
  atk         Int?
  def         Int?
  description String?
  archetype   String?

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)
}

model MagicCard {
  cardId      String   @id
  manaCost    String?
  cmc         Int?
  cardType    String?
  colors      String[]
  oracleText  String?
  power       String?
  toughness   String?
  loyalty     Int?
  artist      String?
  foil        Boolean? @default(false)
  edition     String?

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)
}

model PokemonCard {
  cardId          String  @id
  pokemonType     String?
  hp              Int?
  evolutionStage  String?
  retreatCost     Int?
  weakness        String?
  resistance      String?
  attacks         Json?
  ability         Json?
  isEx            Boolean? @default(false)
  isGx            Boolean? @default(false)
  isV             Boolean? @default(false)
  firstEdition    Boolean? @default(false)
  holo            Boolean? @default(false)

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)
}

model Wishlist {
  id          String         @id @default(uuid())
  userId      String
  name        String
  description String?
  colorHex    String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  user  User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  cards WishlistCard[]

  @@unique([userId, name])
}

model CardHash {
  id         String   @id @default(uuid())
  tcg        String                         // 'magic' | 'pokemon' | 'yugioh'
  externalId String                         // Scryfall ID, YGO ID, etc.
  name       String
  setCode    String?
  setName    String?
  rarity     String?
  imageUrl   String?
  rHash      String                         // Red-channel pHash (hex)
  gHash      String                         // Green-channel pHash (hex)
  bHash      String                         // Blue-channel pHash (hex)
  hashSize   Int      @default(16)          // pHash block size (16 → 256-bit)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([tcg, externalId])
  @@index([tcg])
}

model WishlistCard {
  id            String   @id @default(uuid())
  wishlistId    String
  externalId    String
  tcg           String
  name          String
  setCode       String?
  setName       String?
  rarity        String?
  imageUrl      String?
  imageUrlSmall String?
  setSymbolUrl  String?
  setLogoUrl    String?
  collectorNumber String?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  wishlist Wishlist @relation(fields: [wishlistId], references: [id], onDelete: Cascade)

  @@unique([wishlistId, externalId, tcg])
}

// ---------------------------------------------------------------------------
// Notifications
// ---------------------------------------------------------------------------

model NotificationChannel {
  id        String   @id @default(uuid())
  userId    String
  type      String   // 'email' | 'discord' | 'telegram'
  config    Json     // { email, webhookUrl, chatId, botToken }
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  type      String   // 'price_alert' | 'trade_request' | 'news' | 'import_complete'
  title     String
  body      String
  read      Boolean  @default(false)
  data      Json?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ---------------------------------------------------------------------------
// Deck Building
// ---------------------------------------------------------------------------

model Deck {
  id          String     @id @default(uuid())
  userId      String
  name        String
  description String?
  tcg         String     // 'magic' | 'yugioh' | 'pokemon'
  format      String?    // 'standard', 'modern', 'commander', etc.
  colorHex    String?
  isPublic    Boolean    @default(false)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  cards DeckCard[]

  @@unique([userId, name])
}

model DeckCard {
  id            String  @id @default(uuid())
  deckId        String
  externalId    String
  tcg           String
  name          String
  quantity      Int     @default(1)
  isCommander   Boolean @default(false)
  isSideboard   Boolean @default(false)
  imageUrl      String?
  imageUrlSmall String?
  setCode       String?
  setName       String?
  cardData      Json?

  deck Deck @relation(fields: [deckId], references: [id], onDelete: Cascade)

  @@unique([deckId, externalId, isSideboard])
}

// ---------------------------------------------------------------------------
// Sealed Products
// ---------------------------------------------------------------------------

model SealedProduct {
  id           String    @id @default(uuid())
  tcg          String
  name         String
  productType  String    // 'booster', 'box', 'etb', 'starter'
  setCode      String?
  cardsPerPack Int?
  packsPerBox  Int?
  releaseDate  DateTime?
  imageUrl     String?
  msrp         Decimal?  @db.Decimal(10, 2)
  upc          String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  inventory SealedInventory[]
}

model SealedInventory {
  id            String    @id @default(uuid())
  userId        String
  productId     String
  quantity      Int       @default(1)
  purchasePrice Decimal?  @db.Decimal(10, 2)
  purchaseDate  DateTime?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  product SealedProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
}

// ---------------------------------------------------------------------------
// Pricing & Marketplace
// ---------------------------------------------------------------------------

model PriceAlert {
  id            String    @id @default(uuid())
  userId        String
  cardId        String?
  externalId    String
  tcg           String
  cardName      String
  imageUrl      String?
  targetPrice   Decimal   @db.Decimal(10, 2)
  direction     String    // 'below' | 'above'
  isActive      Boolean   @default(true)
  lastTriggered DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Transaction {
  id         String   @id @default(uuid())
  userId     String
  type       String   // 'purchase' | 'sale' | 'trade'
  cardId     String?
  externalId String?
  tcg        String?
  cardName   String?
  quantity   Int      @default(1)
  amount     Decimal  @db.Decimal(10, 2)
  currency   String   @default("USD")
  platform   String?  // 'tcgplayer', 'cardmarket', 'local', etc.
  notes      String?
  date       DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ShopConnection {
  id        String    @id @default(uuid())
  userId    String
  platform  String    // 'tcgplayer' | 'cardmarket'
  apiKey    String
  apiSecret String?
  sellerId  String?
  enabled   Boolean   @default(true)
  lastSync  DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ---------------------------------------------------------------------------
// Trading
// ---------------------------------------------------------------------------

model Trade {
  id         String   @id @default(uuid())
  senderId   String
  receiverId String
  status     String   @default("pending") // 'pending' | 'accepted' | 'declined' | 'completed' | 'cancelled'
  message    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  sender   User @relation("TradesSent", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("TradesReceived", fields: [receiverId], references: [id], onDelete: Cascade)
  cards    TradeCard[]
}

model TradeCard {
  id             String   @id @default(uuid())
  tradeId        String
  side           String   // 'sender' | 'receiver'
  externalId     String
  tcg            String
  name           String
  quantity       Int      @default(1)
  imageUrl       String?
  estimatedValue Decimal? @db.Decimal(10, 2)

  trade Trade @relation(fields: [tradeId], references: [id], onDelete: Cascade)
}

// ---------------------------------------------------------------------------
// Automation & Shipping
// ---------------------------------------------------------------------------

model Automation {
  id        String   @id @default(uuid())
  userId    String
  name      String
  trigger   String   // 'price_change' | 'new_card_added' | 'schedule'
  action    String   // 'notify' | 'move_to_binder' | 'add_tag' | 'export'
  config    Json
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Shipment {
  id             String    @id @default(uuid())
  userId         String
  carrier        String    // 'usps', 'ups', 'fedex', 'dhl', 'laposte'
  trackingNumber String
  status         String?
  description    String?
  relatedTradeId String?
  lastChecked    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
